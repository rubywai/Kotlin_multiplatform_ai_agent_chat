# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored; this example file is committed as documentation.

# DeepSeek API key, required for the AI agent chat (/chat endpoint).
# Get one at https://platform.deepseek.com/. Without it, the server runs
# but the /chat route returns 503.
DEEPSEEK_API_KEY=sk-your-key-here
